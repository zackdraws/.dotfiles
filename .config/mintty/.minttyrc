ThemeFile=
Term=xterm-256color
ClipShortcuts=no
CtrlShiftShortcuts=yes
Font=Terminess Nerd Font Mono
FontWeight=400
FontHeight=10
Locale=en_US
Charset=UTF-8
Emojis=windows
EmojiPlacement=middle
Font2=Segoe UI Symbol
Font3=Segoe UI Emoji
FontChoice=PictoSymbols:2;|Superscripts and Subscripts:2;
BoldAsFont=yes
BoldAsColour=yes


# Background and foreground
BackgroundColour=50,41,49
ForegroundColour=200,190,200

# Standard 8 colors
Black=65,50,60
Red=230,50,60
Green=150,210,70
Yellow=255,200,85
Blue=45,150,220
Magenta=220,80,140
Cyan=30,180,160
White=245,240,245

# Bold colors (brighter, stronger)
BoldBlack=90,80,95
BoldRed=255,80,90
BoldGreen=175,235,95
BoldYellow=255,225,100
BoldBlue=60,170,240
BoldMagenta=240,100,160
BoldCyan=50,210,190
BoldWhite=255,255,255

# Cursor colors
CursorColour=200,190,200

# Selection colors
HighlightBackgroundColour=80,40,60
HighlightForegroundColour=240,240,240

# Underline
UnderlineColour=255,80,90
Transparency=low
