ThemeFile=
Term=mintty
ClipShortcuts=no
CtrlShiftShortcuts=yes
Font=Terminess Nerd Font Mono
FontWeight=normal
FontHeight=10

# Hopscotch Noir for mintty — soft background, strong colors

# Background and foreground
BackgroundColour=50,41,49
ForegroundColour=200,190,200

# Standard 8 colors
Black=65,50,60
Red=230,50,60
Green=150,210,70
Yellow=255,200,85
Blue=45,150,220
Magenta=255,209,220
Cyan=30,180,160
White=245,240,245

# Bold colors (brighter, stronger)
BoldBlack=90,80,95
BoldRed=255,80,90
BoldGreen=175,235,95
BoldYellow=255,225,100
BoldBlue=60,170,240
BoldMagenta=240,100,160
BoldCyan=50,210,190
BoldWhite=255,255,255

# Bright ANSI colors (same as bolds)
AnsiBlack=90,80,95
AnsiRed=255,80,90
AnsiGreen=175,235,95
AnsiYellow=255,225,100
AnsiBlue=60,170,240
AnsiMagenta=240,100,160
AnsiCyan=50,210,190
AnsiWhite=255,255,255

# Cursor colors
CursorColour=200,190,200
CursorTextColour=50,41,49         # #322931 — same as background

# Selection colors
SelectionColour=80,40,60          # deep muted burgundy
SelectedTextColour=240,240,240    # soft gray for contrast

# Scrollbar
ScrollBarColour=65,50,60          # #41323C

# Underline
UnderlineColour=255,80,90

BoldFont=yes
ItalicFont=yes
UnderlineFont=yes
FontWeight=500
Transparency=off
BellType=0
BellFile=vocal-yip
StatusLine=no
CursorBlinks=no
ConfirmExit=no
CopyAsHTML=2
