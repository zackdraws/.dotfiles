{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/master/schema.json",
  "animation": {
    "enabled": true,
    "duration": 150,
    "fps": 60,
    "style": "EaseOutQuint"
  },
  "border": true,
  "border_colours": {
    "single": "#33ccff",
    "stack": "#00ff99",
    "monocle": "#33ccff",
    "unfocused": "#595959",
    "unfocused_locked": "#595959",
    "floating": "#00ff99"
  },
  "border_implementation": "Komorebi",
  "border_offset": -1,
  "border_style": "Rounded",
  "border_width": 4,
  "cross_monitor_move_behaviour": "Insert",
  "default_container_padding": 2,
  "default_workspace_padding": 0,
  "floating_layer_behaviour": "Tile",
  "float_override": true,
  "ignore_rules": [
    {
      "kind": "Exe",
      "id": "PowerToys.PowerLauncher.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "Microsoft.CmdPal.UI.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "Microsoft.CmdPal.Ext.PowerToys.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "PowerToys.QuickAccess.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Title",
      "id": "PowerToys Run",
      "matching_strategy": "Contains"
    },
    {
      "kind": "Title",
      "id": "Command Palette",
      "matching_strategy": "Contains"
    }
  ],
  "mouse_follows_focus": true,
  "resize_delta": 40,
  "toggle_float_placement": "CenterAndResize",
  "transparency": false,
  "unmanaged_window_operation_behaviour": "Op",
  "window_container_behaviour": "Create",
  "window_hiding_behaviour": "Cloak",
  "manage_rules": [
    {
      "kind": "Exe",
      "id": "mintty.exe",
      "matching_strategy": "Equals"
    }
  ],
  "monitors": [
    {
      "container_padding": 2,
      "workspace_padding": 0,
      "workspaces": [
        {
          "name": "●",
          "layout": "BSP",
          "tile": true,
          "container_padding": 2,
          "workspace_padding": 0
        },
        {
          "name": "●",
          "layout": "BSP",
          "tile": true,
          "container_padding": 2,
          "workspace_padding": 0
        },
        {
          "name": "●",
          "layout": "BSP",
          "tile": true,
          "container_padding": 2,
          "workspace_padding": 0
        },
        {
          "name": "●",
