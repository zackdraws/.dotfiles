{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/master/schema.json",
  "animation": {
    "enabled": true,
    "duration": 150,
    "fps": 60,
    "style": "EaseOutQuint"
  },
  "border": true,
  "border_colours": {
    "single": "#33ccff",
    "stack": "#00ff99",
    "monocle": "#33ccff",
    "unfocused": "#595959",
    "unfocused_locked": "#595959",
    "floating": "#00ff99"
  },
  "border_implementation": "Komorebi",
  "border_offset": -1,
  "border_style": "Rounded",
  "border_width": 4,
  "cross_monitor_move_behaviour": "Insert",
  "default_container_padding": 2,
  "default_workspace_padding": 0,
  "floating_layer_behaviour": "Tile",
  "float_override": false,
  "mouse_follows_focus": true,
  "resize_delta": 40,
  "toggle_float_placement": "CenterAndResize",
  "transparency": false,
  "unmanaged_window_operation_behaviour": "Op",
  "window_container_behaviour": "Create",
  "window_hiding_behaviour": "Cloak",
  "monitors": [
    {
      "container_padding": 2,
      "workspace_padding": 0,
      "workspaces": [
        {
          "name": "1",
          "layout": "BSP",
          "tile": true,
          "container_padding": 2,
          "workspace_padding": 0
        },
        {
          "name": "2",
          "layout": "BSP",
          "tile": true,
          "container_padding": 2,
          "workspace_padding": 0
        },
        {
          "name": "3",
          "layout": "BSP",
          "tile": true,
          "container_padding": 2,
          "workspace_padding": 0
        },
        {
          "name": "4",
          "layout": "BSP",
          "tile": true,
          "container_padding": 2,
          "workspace_padding": 0
        },
        {
          "name": "5",
          "layout": "BSP",
          "tile": true,
          "container_padding": 2,
          "workspace_padding": 0
        },
        {
          "name": "6",
          "layout": "BSP",
          "tile": true,
          "container_padding": 2,
          "workspace_padding": 0
        },
        {
          "name": "7",
          "layout": "BSP",
          "tile": true,
          "container_padding": 2,
          "workspace_padding": 0
        },
        {
          "name": "8",
          "layout": "BSP",
          "tile": true,
          "container_padding": 2,
          "workspace_padding": 0
        },
        {
          "name": "9",
